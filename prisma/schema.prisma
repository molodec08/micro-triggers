// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Триггер 1: мигающая вкладка браузера при уходе со страницы с товаром в корзине
model BlinkingTabTrigger {
  id        String   @id @default(cuid())
  shop      String   @unique
  enabled   Boolean  @default(false)
  message   String   @default("Не уходи! Твоя корзина ждёт 🛒")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Триггер 2: минималистичный exit-intent попап с текстом и промокодом
model ExitPopupTrigger {
  id           String   @id @default(cuid())
  shop         String   @unique
  enabled      Boolean  @default(false)
  message      String   @default("Подождите! Вот скидка для вас")
  discountCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Триггер 3: звуковой сигнал при добавлении в корзину / на checkout
model SoundTrigger {
  id            String   @id @default(cuid())
  shop          String   @unique
  enabled       Boolean  @default(false)
  soundFileUrl  String?
  playOnAddCart Boolean  @default(true)
  playOnCheckout Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
